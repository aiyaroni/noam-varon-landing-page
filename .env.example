# ─── Admin ────────────────────────────────────────────────────────────────────
# Password for the admin panel (double-click the footer copyright to open)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign admin session tokens (any random string)
ADMIN_SECRET=change-me-to-a-random-secret

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Noam Varon Studio <your@gmail.com>"

# ─── Data Persistence ─────────────────────────────────────────────────────────
# Upstash Redis — required for persistent storage on Vercel.
# Get from: https://console.upstash.com → Create Database → REST API tab
# Without these, appointments are stored in-memory only (lost on restart).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Frontend ─────────────────────────────────────────────────────────────────
# WhatsApp number for booking confirmation redirect (digits only, with country code)
VITE_WHATSAPP_NUMBER=972524040859
